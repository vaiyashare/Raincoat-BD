{
  "entities": {
    "Order": {
      "title": "Raincoat Order",
      "description": "An order placed by a customer on the landing page",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Global unique ID of the order" },
        "name": { "type": "string", "description": "Recipient full name" },
        "village": { "type": "string", "description": "Address details" },
        "policeStation": { "type": "string", "description": "Thana/Police station name" },
        "district": { "type": "string", "description": "District name" },
        "phone": { "type": "string", "description": "Mobile number" },
        "size": { "type": "string", "description": "Raincoat Size" },
        "color": { "type": "string", "description": "Raincoat Color" },
        "weight": { "type": "number", "description": "Body weight in kg" },
        "heightFeet": { "type": "number", "description": "Height feet part" },
        "heightInches": { "type": "number", "description": "Height inches part" },
        "price": { "type": "number", "description": "Total final cash amount" },
        "status": { "type": "string", "enum": ["Pending", "Shipped", "Delivered", "Cancelled"], "description": "Order shipment processing status" },
        "createdAt": { "type": "string", "description": "Creation timestamp string" }
      },
      "required": ["id", "name", "village", "phone", "size", "color", "weight", "heightFeet", "heightInches", "price", "status", "createdAt"]
    },
    "IncompleteOrder": {
      "title": "Incomplete Order",
      "description": "An incomplete checkout form draft session",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Session ID" },
        "name": { "type": "string", "description": "Name prefix typed" },
        "phone": { "type": "string", "description": "Incomplete mobile format" },
        "village": { "type": "string", "description": "Incomplete location typed" },
        "size": { "type": "string", "description": "Selected sizing" },
        "color": { "type": "string", "description": "Selected color" },
        "weight": { "type": "number", "description": "Draft body weight in kg" },
        "heightFeet": { "type": "number", "description": "Draft height feet" },
        "heightInches": { "type": "number", "description": "Draft height inches" },
        "price": { "type": "number", "description": "Computed final price tag" },
        "createdAt": { "type": "string", "description": "Initial draft date" },
        "lastUpdatedAt": { "type": "string", "description": "Last typist update" },
        "fieldsFilledCount": { "type": "number", "description": "Step fill counter" }
      },
      "required": ["id", "createdAt", "lastUpdatedAt", "fieldsFilledCount"]
    },
    "Inventory": {
      "title": "Inventory Item",
      "description": "Stock inventory levels for product color and size combinations",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Variant combination ID" },
        "color": { "type": "string", "description": "Product color variant" },
        "size": { "type": "string", "description": "Product size variant" },
        "quantity": { "type": "number", "description": "Quantity in stock" },
        "lowStockAlert": { "type": "number", "description": "Alert limit threshold" }
      },
      "required": ["id", "color", "size", "quantity"]
    },
    "Media": {
      "title": "Media Item",
      "description": "An uploaded image file or remote image url with metadata stored for custom landing page carousel",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Global unique id for media reference" },
        "url": { "type": "string", "description": "Base64 encoded string data or remote https image web link address" },
        "title": { "type": "string", "description": "Brief header title of slide" },
        "tag": { "type": "string", "description": "Badge sticker text" },
        "description": { "type": "string", "description": "Description of the slide product feature overlay" },
        "orderIndex": { "type": "number", "description": "Sort rendering index tracker" },
        "createdAt": { "type": "string", "description": "Datetime marker string" }
      },
      "required": ["id", "url", "title", "tag", "orderIndex"]
    },
    "IntegrationsConfig": {
      "title": "Integrations Config",
      "description": "Third-party pixel & tracking integrations and courier configurations",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Global unique ID, usually 'integrations'" },
        "fb_pixel_id": { "type": "string", "description": "Meta Facebook Pixel ID" },
        "fb_pixel_enabled": { "type": "boolean", "description": "Is Meta Pixel enabled?" },
        "fb_capi_enabled": { "type": "boolean", "description": "Is Conversion API enabled?" },
        "fb_advanced_matching": { "type": "boolean", "description": "Is Advanced Matching enabled?" },
        "fb_capi_token": { "type": "string", "description": "Conversion API access token" },
        "fb_test_event_enabled": { "type": "boolean", "description": "Is test event mode enabled?" },
        "fb_test_event_code": { "type": "string", "description": "Test event code format string" },
        "ga_track_id": { "type": "string", "description": "Google Analytics tracking ID" },
        "raincoat_header_snippets": { "type": "string", "description": "Header injection snippets HTML" },
        "raincoat_footer_snippets": { "type": "string", "description": "Footer injection snippets HTML" },
        "raincoat_courier_inside": { "type": "number", "description": "Courier charge inside Dhaka" },
        "raincoat_courier_sub": { "type": "number", "description": "Courier charge sub Dhaka" },
        "raincoat_courier_outside": { "type": "number", "description": "Courier charge outside Dhaka" }
      },
      "required": ["id"]
    },
    "ActiveSession": {
      "title": "Active Session",
      "description": "Real-time live visitor activity session tracking details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Global unique session ID" },
        "city": { "type": "string", "description": "Approximate city of the visitor" },
        "country": { "type": "string", "description": "Approximate country of the visitor" },
        "countryCode": { "type": "string", "description": "Two letter country code" },
        "page": { "type": "string", "description": "Active page path or hash code" },
        "browser": { "type": "string", "description": "Visitor web browser type" },
        "os": { "type": "string", "description": "Visitor device operating system" },
        "createdAt": { "type": "string", "description": "Time the session started" },
        "updatedAt": { "type": "string", "description": "Last heartbeat update timestamp" }
      },
      "required": ["id", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Shop Product",
      "description": "A product available in the shop",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Global unique ID of the product" },
        "title": { "type": "string", "description": "Product title name" },
        "slug": { "type": "string", "description": "Product slug for lookup" },
        "description": { "type": "string", "description": "Full product description text" },
        "price": { "type": "number", "description": "Price in TK" },
        "image": { "type": "string", "description": "Main image (url or base64)" },
        "category": { "type": "string", "description": "Category name" },
        "sizes": { "type": "array", "items": { "type": "string" }, "description": "List of available sizes" },
        "colors": { "type": "array", "items": { "type": "string" }, "description": "List of available colors" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Additional gallery images (url or base64)" },
        "addDeliveryCharge": { "type": "boolean", "description": "Should courier charges apply?" }
      },
      "required": ["id", "title", "description", "price", "image", "category", "sizes", "colors"]
    },
    "Review": {
      "title": "Customer Review",
      "description": "Customer comments and ratings with rating counts",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique Review ID" },
        "customerName": { "type": "string", "description": "Name of reviewing buyer" },
        "phoneNumberMasked": { "type": "string", "description": "Reviewer masked phone number" },
        "verifiedPurchase": { "type": "boolean", "description": "Whether purchase is confirmed and verified" },
        "avatarUrl": { "type": "string", "description": "Reviewer avatar profile image" },
        "reviewDate": { "type": "string", "description": "Date statement string" },
        "rating": { "type": "number", "description": "Star rating number" },
        "title": { "type": "string", "description": "Title statement header" },
        "badge": { "type": "string", "description": "Subtext or award tag line" },
        "helpfulCount": { "type": "number", "description": "Upvote user metric count" }
      },
      "required": ["id", "customerName", "phoneNumberMasked", "verifiedPurchase", "rating"]
    },
    "CallingAgent": {
      "title": "Calling Agent",
      "description": "Calling agents login accounts managed by main administrator",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "username", "password", "createdAt"]
    },
    "CallingAgentLog": {
      "title": "Calling Agent Activity Log",
      "description": "Log actions performed by a calling agent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentUsername": { "type": "string" },
        "action": { "type": "string" },
        "orderId": { "type": "string" },
        "timestamp": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "agentUsername", "action", "orderId", "timestamp"]
    },
    "MenuBarConfig": {
      "title": "Menu Bar Configuration",
      "description": "Customizable landing pages top navigation menu bar",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brandName": { "type": "string" },
        "visible": { "type": "boolean" },
        "enableCategories": { "type": "boolean" },
        "categoriesIcon": { "type": "string" },
        "links": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["id", "brandName", "visible", "enableCategories", "links"]
    },
    "Coupon": {
      "title": "Discount Coupon",
      "description": "Promo coupon used by customers during checkout",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Lowercase of code used as doc ID" },
        "code": { "type": "string", "description": "Case-sensitive entered code" },
        "discountType": { "type": "string", "enum": ["money", "percentage"], "description": "Discount in cash Tk or percentage %" },
        "discountValue": { "type": "number", "description": "The cash or percentage amount" },
        "validityDays": { "type": "number", "description": "Days the coupon is valid for" },
        "createdAt": { "type": "string", "description": "ISO timestamp for creation moment" }
      },
      "required": ["id", "code", "discountType", "discountValue", "validityDays", "createdAt"]
    },
    "Subscriber": {
      "title": "Newsletter Subscriber",
      "description": "An email subscription record for newsletters",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Global unique ID of the subscriber" },
        "email": { "type": "string", "description": "Subscriber email address" },
        "createdAt": { "type": "string", "description": "Creation timestamp string" }
      },
      "required": ["id", "email", "createdAt"]
    }
  },
  "firestore": {
    "subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Store newsletter and updates subscriber email entries"
    },
    "coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Store promo coupons available in checkout"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Store authentic customer review entries and photo testimonials"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Products available in the shop collection"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Raincoat Orders Collection"
    },
    "incompleteOrders/{incompleteId}": {
      "schema": "IncompleteOrder",
      "description": "Incomplete Checkout Form Drafts Collection"
    },
    "inventory/{itemId}": {
      "schema": "Inventory",
      "description": "Variant stock levels"
    },
    "media/{mediaId}": {
      "schema": "Media",
      "description": "Customized user slideshow carousel media items collection"
    },
    "settings/{settingId}": {
      "schema": "IntegrationsConfig",
      "description": "Global app settings and integrations configurations"
    },
    "activeSessions/{sessionId}": {
      "schema": "ActiveSession",
      "description": "Real-time active web visitor tracking sessions"
    },
    "callingAgents/{agentId}": {
      "schema": "CallingAgent",
      "description": "Agent accounts created by admin for sales calls"
    },
    "callingAgentLogs/{logId}": {
      "schema": "CallingAgentLog",
      "description": "Sales agent action trackers"
    }
  }
}
